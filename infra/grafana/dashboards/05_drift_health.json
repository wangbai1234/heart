        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "expr": "heart_deployments_total",
        "iconColor": "#5794F2",
        "name": "Deployments",
        "tagKeys": "version,env",
        "textFormat": "Deploy {{version}}",
        "titleFormat": "Deployment"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "expr": "heart_drift_baseline_updates_total",
        "iconColor": "#EAB839",
