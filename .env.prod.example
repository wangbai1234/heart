# Heart/yuoyuo Production Environment Variables
# Copy to .env.prod and fill in your values
# DO NOT commit this file to Git

# ─── Database ───
POSTGRES_USER=heart
POSTGRES_PASSWORD=<generate-with-openssl-rand-hex-32>
POSTGRES_DB=heart

# ─── Redis ───
REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>

# ─── Application ───
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ─── LLM Providers ───
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Model Configuration ───
MAIN_LLM_MODEL=deepseek-chat
# Note: deepseek-reasoner is expensive; deepseek-chat is recommended for CHEAP_LLM_MODEL
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service (optional) ───
EMBEDDING_API_KEY=<your-siliconflow-api-key>
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ─── Security / Auth (RS256 recommended for production) ───
# Generate keypair:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Paste PEM contents as single lines (escape newlines as \n in env file)
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=<paste-private-pem-here>
JWT_PUBLIC_KEY=<paste-public-pem-here>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
# Generate with: openssl rand -hex 32
OTP_PEPPER=<generate-random-pepper>
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

# ─── Email (Resend) ───
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@mail.yuoyuo.app
EMAIL_FROM_NAME=yuoyuo
RESEND_API_KEY=<your-resend-api-key>

# ─── CORS ───
# Add your Cloudflare Tunnel URL for mobile testing, or leave as app domain only
CORS_ALLOWED_ORIGINS=https://yuoyuo.app,https://www.yuoyuo.app

# ─── Credits / Billing (centesimal: 1 display credit = 100 fen internally) ───
# SIGNUP_GRANT_CREDITS: 10000 = 100 display credits granted at signup
# CREDITS_PER_TEXT_TURN / CREDITS_PER_VOICE_TURN: legacy turn billing (kept for reference)
# CREDITS_COST_TEXT_MESSAGE / CREDITS_COST_VOICE_MESSAGE: active per-bubble billing
SIGNUP_GRANT_CREDITS=10000
CREDITS_PER_TEXT_TURN=100
CREDITS_PER_VOICE_TURN=500
CREDITS_COST_TEXT_MESSAGE=50
CREDITS_COST_VOICE_MESSAGE=500

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0
ALERT_COST_THRESHOLD=5.0

# ─── Feature Flags ───
ENABLE_VOICE=true
ENABLE_VIDEO=false
ENABLE_CRITIC_AGENT=true
CRITIC_SAMPLING_RATE=0.3
ENABLE_WELLBEING_MONITOR=true

# ─── Background Workers ───
# DO NOT set HEART_WORKERS_ENABLED=true here — workers run in the encoder-worker
# container (docker-compose.prod.yml). Setting it here would cause duplicate workers
# in the api container.
# HEART_WORKERS_ENABLED is intentionally absent (defaults to false in the api service).

# ─── Memory Promoter (L3→L4 identity fact promotion) ───
# Runs in the encoder-worker container (HEART_WORKERS_ENABLED=true).
MEMORY_PROMOTER_ENABLED=true
MEMORY_PROMOTER_INTERVAL_SECS=300
MEMORY_PROMOTER_MIN_MENTIONS=3
MEMORY_PROMOTER_MIN_CROSS_SESSIONS=2
MEMORY_PROMOTER_MIN_CONFIDENCE=0.8
MEMORY_PROMOTER_MIN_AGE_DAYS=1

# ─── Inner Loop (Proactive Messages) ───
HEART_INNER_LOOP_ENABLED=true
HEART_INNER_LOOP_INTERVAL_S=3600
PROACTIVE_LLM_ENABLED=true
# PROACTIVE_V2_ENABLED: route through full ComposerService (time-based probability table).
# false = old template/thin-LLM path; true = v2 (default false, enable after 3-day gray test)
PROACTIVE_V2_ENABLED=false
PROACTIVE_V2_DAILY_QUOTA=2
PROACTIVE_V2_COOLDOWN_MINUTES=240

# ─── Voice Provider — choose one: mimo or minimax ───
#
# Option A: MiMo TTS (recommended, Token Plan keys)
VOICE_PROVIDER=mimo
VOICE_FALLBACK_ENABLED=true
MIMO_API_KEY=<your-mimo-api-key>
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-tts-voiceclone
MIMO_REFERENCE_AUDIO_PATH=assets/reference_voices/rin.mp3
#
# Option B: MiniMax TTS (fallback / alternative)
# VOICE_PROVIDER=minimax
# MINIMAX_API_KEY=<your-minimax-api-key>
# MINIMAX_GROUP_ID=<your-minimax-group-id>
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1  # mainland endpoint (required for UGC voice IDs)
# MINIMAX_TTS_MODEL=speech-2.8-hd
# MINIMAX_LANGUAGE_BOOST=Chinese
# MINIMAX_RIN_CLONE_VOICE_ID=<clone-voice-id-for-rin>
# MINIMAX_DOROTHY_VOICE_ID=<clone-voice-id-for-dorothy>

# ─── S3 / Object Storage（自建 MinIO，无需信用卡 / 无需备案）───
# 头像 + 克隆音色样本存储。默认用 docker-compose.prod.yml 里的 minio 容器（同机自建，
# S3 兼容，boto3 直连，零代码改动）。bucket 首次上传时自动创建，无需手动建。
#
#   • S3_ENDPOINT_URL 固定填 http://minio:9000（容器内网地址，不对公网暴露）
#   • S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY 就是 MinIO 的 root 账号密码，
#     compose 会用同一对值启动 minio 容器 —— 两边必须一致。密码 ≥ 8 位，建议：
#       openssl rand -hex 16
#   • S3_PUBLIC_BASE_URL 留空即可：头像经后端 /api/profile/avatar-file/ 代理回传；
#     语音克隆在 S3 端点为内网时自动走 TTS provider 自带上传（storage.py 已处理）。
#
# 想让媒体走公网直链（性能更好，或 Fish/MiMo 克隆需可公网抓取的 URL）再考虑：
# 用 Caddy 把 media.yuoyuo.app 反代到 minio，并设 S3_PUBLIC_BASE_URL=https://media.yuoyuo.app/<bucket>。
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=yuoyuo-minio
S3_SECRET_ACCESS_KEY=<generate-with-openssl-rand-hex-16>
S3_BUCKET_NAME=yuoyuo-media-prod
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# ─── Observability ───
SENTRY_DSN=<your-sentry-dsn>

# ══════════════════════════════════════════════════════════════════════════════
# 商业化 V1 · yuoyuo_coin（会员 + 多模型 + Fish 语音 + 邀请）
# 详见 docs/upgrade/yuoyuo_coin/。⚠️ 这些 key 若曾在明文文档出现过，上线前务必轮换。
# 高级模型 / Fish 未配置时按会员权益门控 + 降级链兜底，不影响免费 DeepSeek 主链路。
# ══════════════════════════════════════════════════════════════════════════════

# ⚠️ 变量名严格以 backend/heart/core/config.py 为准（extra="ignore"：拼错名字会被静默忽略，值不生效）。
#
# ─── Grok（OpenAI 兼容；grok.py 在 base_url 之后自动拼 /v1/chat/completions）───
GROK_API_KEY=<your-grok-api-key>
GROK_BASE_URL=https://api.x.ai         # 只填域名根，勿加 /v1（代理则填代理根）
GROK_MODEL=grok-3-mini-fast

# ─── Claude（默认 anthropic /v1/messages；走 OpenAI 兼容代理时 STYLE=openai-compat）───
CLAUDE_API_KEY=<your-claude-api-key>
CLAUDE_BASE_URL=https://api.anthropic.com   # 只填域名根，勿加 /v1
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_API_STYLE=anthropic              # anthropic | openai-compat（是"风格"，不是模型名）

# ─── Fish Audio TTS + 声音克隆（变量名是 FISH_API_KEY，不是 FISH_AUDIO_API_KEY）───
# 用 fishaudio.org 开放网关：base 已含 /api/open/v1，合成 POST /speech/tts、克隆 POST /voices。
# ⚠️ 不是官方 api.fish.audio（那套是 /model + /v1/tts + reference_id，契约不同，会 500/404）。
FISH_API_KEY=<your-fish-audio-api-key>
FISH_BASE_URL=https://fishaudio.org/api/open/v1
FISH_MODEL=fishaudio-s21pro-flash
# 实时流式 TTS（WebSocket + MessagePack，model_id=已存的 Fish voiceId）。开启后 Fish
# 音色逐句喂文本、增量出声，首音频远快于阻塞 REST。任何实时错误自动回退 REST 合成。
# 上线先留 false，确认 key 可用后置 true 灰度验证。
FISH_REALTIME_ENABLED=false
FISH_REALTIME_URL=wss://realtime.fishaudio.org/v1/tts/live

# ─── 按模型/动作消耗（单位：yuoyuo币，后端 ×100 存 fen；DeepSeek 文本免费=0）───
GROK_COST_CREDITS=3
CLAUDE_COST_CREDITS=12
MIMO_TTS_COST_CREDITS=5
FISH_TTS_COST_CREDITS=8
CLONE_MIMO_COST_CREDITS=50
CLONE_FISH_COST_CREDITS=100

# ─── 会员定价（¥/月，仅用于 /pricing 展示）───
MEMBERSHIP_PLUS_PRICE_MONTHLY=39
MEMBERSHIP_IMMERSIVE_PRICE_MONTHLY=79
# 档位权益（月度赠币 + 可用模型/TTS/克隆）= MEMBERSHIP_TIERS_CONFIG（单行 JSON）。
# 代码已内置默认值；仅在需要改档位时取消注释整体覆盖，❌ 切勿留空（json 解析失败会令权益校验全崩）：
# MEMBERSHIP_TIERS_CONFIG={"free":{"models":["deepseek"],"tts":["mimo"],"clone":[],"monthly_grant":0},"plus":{"models":["deepseek","grok"],"tts":["mimo","fish"],"clone":["mimo","fish"],"monthly_grant":400},"immersive":{"models":["deepseek","grok","claude"],"tts":["mimo","fish"],"clone":["mimo","fish"],"monthly_grant":800}}

# ─── 邀请奖励（单位：yuoyuo币；变量名以 config.py 为准）───
INVITE_REFERRAL_GRANT_COINS=100
INVITE_MILESTONE_5_COINS=300
INVITE_MILESTONE_10_COINS=1000

# ─── 爱发电（对账 + 自动履约；webhook 用 remark 里的 binding_code 绑定用户）───
# AFDIAN_WEBHOOK_TOKEN 双重用途：①作为 webhook 回调 URL 的密钥（爱发电 webhook 不带签名，
# 我们靠 URL 里的 token 鉴权）②作为查询订单 API 的 sign token。
# 在爱发电后台把 Webhook URL 配成：
#   https://yuoyuo.app/api/webhooks/afdian?token=<AFDIAN_WEBHOOK_TOKEN>
# （token 不带上会被 403 拒绝。）AFDIAN_USER_ID + token 见 爱发电 → 创作者中心 → 开发者。
AFDIAN_USER_ID=<your-afdian-user-id>
AFDIAN_WEBHOOK_TOKEN=<your-afdian-webhook-token>
AFDIAN_SPONSOR_URL=https://ifdian.net/a/yuoyuo
# SKU → 权益映射（单行 JSON）。留空即 {} = 不履约任何订单（付款进来也不发货）。
# 键可用 plan_id（会员=爱发电"方案"）或 sku_id（币包=爱发电"商品"，plan_id 为空，靠 sku_id 匹配）。
# 币包用 "coins"（不是 credits）；会员用 tier+days。商品数量>1 时币按 count 倍发放。例：
# {"<plus方案id>":{"type":"membership","tier":"plus","days":30},"<沉浸方案id>":{"type":"membership","tier":"immersive","days":30},"<6元商品sku_id>":{"type":"coins","coins":60},"<18元商品sku_id>":{"type":"coins","coins":198},"<128元商品sku_id>":{"type":"coins","coins":1580}}
AFDIAN_SKU_MAP={}
