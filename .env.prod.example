# Heart/yuoyuo Production Environment Variables
# Copy to .env.prod and fill in your values
# DO NOT commit this file to Git

# ─── Database ───
POSTGRES_USER=heart
POSTGRES_PASSWORD=<generate-with-openssl-rand-hex-32>
POSTGRES_DB=heart

# ─── Redis ───
REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>

# ─── Application ───
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ─── LLM Providers ───
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Model Configuration ───
MAIN_LLM_MODEL=deepseek-chat
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service (optional) ───
EMBEDDING_API_KEY=<your-siliconflow-api-key>
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ─── Security / Auth ───
# Generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048 && openssl rsa -pubout -in private.pem -out public.pem
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=<paste-private-pem-here>
JWT_PUBLIC_KEY=<paste-public-pem-here>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
# Generate with: openssl rand -hex 32
OTP_PEPPER=<generate-random-pepper>
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

# ─── Email (Resend) ───
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@mail.yuoyuo.app
EMAIL_FROM_NAME=yuoyuo
RESEND_API_KEY=<your-resend-api-key>

# ─── CORS ───
CORS_ALLOWED_ORIGINS=https://yuoyuo.app,https://www.yuoyuo.app

# ─── Credits / Billing ───
SIGNUP_GRANT_CREDITS=100
CREDITS_PER_TEXT_TURN=1
CREDITS_PER_VOICE_TURN=5

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0
ALERT_COST_THRESHOLD=5.0

# ─── Observability ───
SENTRY_DSN=<your-sentry-dsn>
