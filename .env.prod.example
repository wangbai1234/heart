# Heart/yuoyuo Production Environment Variables
# Copy to .env.prod and fill in your values
# DO NOT commit this file to Git

# ─── Database ───
POSTGRES_USER=heart
POSTGRES_PASSWORD=<generate-with-openssl-rand-hex-32>
POSTGRES_DB=heart

# ─── Redis ───
REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>

# ─── Application ───
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ─── LLM Providers ───
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Model Configuration ───
MAIN_LLM_MODEL=deepseek-chat
# Note: deepseek-reasoner is expensive; deepseek-chat is recommended for CHEAP_LLM_MODEL
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service (optional) ───
EMBEDDING_API_KEY=<your-siliconflow-api-key>
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ─── Security / Auth (RS256 recommended for production) ───
# Generate keypair:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Paste PEM contents as single lines (escape newlines as \n in env file)
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=<paste-private-pem-here>
JWT_PUBLIC_KEY=<paste-public-pem-here>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
# Generate with: openssl rand -hex 32
OTP_PEPPER=<generate-random-pepper>
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

# ─── Email (Resend) ───
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@mail.yuoyuo.app
EMAIL_FROM_NAME=yuoyuo
RESEND_API_KEY=<your-resend-api-key>

# ─── CORS ───
# Add your Cloudflare Tunnel URL for mobile testing, or leave as app domain only
CORS_ALLOWED_ORIGINS=https://yuoyuo.app,https://www.yuoyuo.app

# ─── Credits / Billing (centesimal: 1 display credit = 100 fen internally) ───
# SIGNUP_GRANT_CREDITS: 10000 = 100 display credits granted at signup
# CREDITS_PER_TEXT_TURN / CREDITS_PER_VOICE_TURN: legacy turn billing (kept for reference)
# CREDITS_COST_TEXT_MESSAGE / CREDITS_COST_VOICE_MESSAGE: active per-bubble billing
SIGNUP_GRANT_CREDITS=10000
CREDITS_PER_TEXT_TURN=100
CREDITS_PER_VOICE_TURN=500
CREDITS_COST_TEXT_MESSAGE=50
CREDITS_COST_VOICE_MESSAGE=500

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0
ALERT_COST_THRESHOLD=5.0

# ─── Feature Flags ───
ENABLE_VOICE=true
ENABLE_VIDEO=false
ENABLE_CRITIC_AGENT=true
CRITIC_SAMPLING_RATE=0.3
ENABLE_WELLBEING_MONITOR=true

# ─── Background Workers ───
# DO NOT set HEART_WORKERS_ENABLED=true here — workers run in the encoder-worker
# container (docker-compose.prod.yml). Setting it here would cause duplicate workers
# in the api container.
# HEART_WORKERS_ENABLED is intentionally absent (defaults to false in the api service).

# ─── Memory Promoter (L3→L4 identity fact promotion) ───
# Runs in the encoder-worker container (HEART_WORKERS_ENABLED=true).
MEMORY_PROMOTER_ENABLED=true
MEMORY_PROMOTER_INTERVAL_SECS=300
MEMORY_PROMOTER_MIN_MENTIONS=3
MEMORY_PROMOTER_MIN_CROSS_SESSIONS=2
MEMORY_PROMOTER_MIN_CONFIDENCE=0.8
MEMORY_PROMOTER_MIN_AGE_DAYS=1

# ─── Inner Loop (Proactive Messages) ───
HEART_INNER_LOOP_ENABLED=true
HEART_INNER_LOOP_INTERVAL_S=3600
PROACTIVE_LLM_ENABLED=true
# PROACTIVE_V2_ENABLED: route through full ComposerService (time-based probability table).
# false = old template/thin-LLM path; true = v2 (default false, enable after 3-day gray test)
PROACTIVE_V2_ENABLED=false
PROACTIVE_V2_DAILY_QUOTA=2
PROACTIVE_V2_COOLDOWN_MINUTES=240

# ─── Voice Provider — choose one: mimo or minimax ───
#
# Option A: MiMo TTS (recommended, Token Plan keys)
VOICE_PROVIDER=mimo
VOICE_FALLBACK_ENABLED=true
MIMO_API_KEY=<your-mimo-api-key>
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-tts-voiceclone
MIMO_REFERENCE_AUDIO_PATH=assets/reference_voices/rin.wav
#
# Option B: MiniMax TTS (fallback / alternative)
# VOICE_PROVIDER=minimax
# MINIMAX_API_KEY=<your-minimax-api-key>
# MINIMAX_GROUP_ID=<your-minimax-group-id>
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1  # mainland endpoint (required for UGC voice IDs)
# MINIMAX_TTS_MODEL=speech-2.8-hd
# MINIMAX_LANGUAGE_BOOST=Chinese
# MINIMAX_RIN_CLONE_VOICE_ID=<clone-voice-id-for-rin>
# MINIMAX_DOROTHY_VOICE_ID=<clone-voice-id-for-dorothy>

# ─── S3 / Object Storage ───
# Required for user-cloned voice sample storage and character avatar uploads.
S3_ENDPOINT_URL=<your-s3-endpoint>
S3_ACCESS_KEY_ID=<your-s3-access-key>
S3_SECRET_ACCESS_KEY=<your-s3-secret-key>
S3_BUCKET_NAME=<your-s3-bucket>
S3_REGION=us-east-1

# ─── Observability ───
SENTRY_DSN=<your-sentry-dsn>

# ══════════════════════════════════════════════════════════════════════════════
# 商业化 V1 · yuoyuo_coin（会员 + 多模型 + Fish 语音 + 邀请）
# 详见 docs/upgrade/yuoyuo_coin/。⚠️ 这些 key 若曾在明文文档出现过，上线前务必轮换。
# 高级模型 / Fish 未配置时按会员权益门控 + 降级链兜底，不影响免费 DeepSeek 主链路。
# ══════════════════════════════════════════════════════════════════════════════

# ─── Grok（OpenAI 兼容 /v1/chat/completions）───
GROK_API_KEY=<your-grok-api-key>
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# ─── Claude（anthropic /v1/messages；style=anthropic|openai）───
CLAUDE_API_KEY=<your-claude-api-key>
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_API_STYLE=anthropic

# ─── Fish Audio TTS + 声音克隆 ───
FISH_AUDIO_API_KEY=<your-fish-audio-api-key>
FISH_BASE_URL=https://api.fish.audio
FISH_MODEL=speech-1.6

# ─── 按模型/动作消耗（单位：yuoyuo币，后端 ×100 存 fen；DeepSeek 文本免费=0）───
GROK_COST_CREDITS=3
CLAUDE_COST_CREDITS=12
MIMO_TTS_COST_CREDITS=5
FISH_TTS_COST_CREDITS=8
CLONE_MIMO_COST_CREDITS=50
CLONE_FISH_COST_CREDITS=100

# ─── 会员（30 天 + 月度赠币；tier: free|plus|immersive）───
MEMBERSHIP_DURATION_DAYS=30
MEMBERSHIP_PLUS_MONTHLY_CREDITS=400
MEMBERSHIP_IMMERSIVE_MONTHLY_CREDITS=800

# ─── 邀请奖励（单位：yuoyuo币）───
INVITE_REWARD_CREDITS=100
INVITE_STAGE5_BONUS_CREDITS=300
INVITE_STAGE10_BONUS_CREDITS=1000

# ─── 爱发电（对账 + 自动履约；webhook 用 remark 绑定 binding_code）───
# AFDIAN_USER_ID / AFDIAN_WEBHOOK_TOKEN 见爱发电后台；SKU_MAP 单行 JSON
AFDIAN_USER_ID=<your-afdian-user-id>
AFDIAN_WEBHOOK_TOKEN=<your-afdian-webhook-token>
AFDIAN_SPONSOR_URL=https://afdian.com/a/yuoyuo
# 例：{"plan_plus":{"type":"membership","tier":"plus"},"plan_immersive":{"type":"membership","tier":"immersive"},"pack_6":{"type":"coins","credits":60},"pack_18":{"type":"coins","credits":220},"pack_48":{"type":"coins","credits":650},"pack_128":{"type":"coins","credits":2000}}
AFDIAN_SKU_MAP=
