# Caddyfile for Heart/yuoyuo production deployment
# 
# Features:
# - Automatic HTTPS with Let's Encrypt
# - Reverse proxy to API backend
# - WebSocket support for /api/chat/ws
# - Static file serving for frontend SPA
# - Security headers
# - Compression

yuoyuo.app, www.yuoyuo.app {
	# API reverse proxy
	handle /api/* {
		reverse_proxy api:8000
	}

	# WebSocket endpoint (Caddy handles Upgrade automatically)
	handle /api/chat/ws {
		reverse_proxy api:8000
	}

	# Health check endpoint (for monitoring)
	handle /health/* {
		reverse_proxy api:8000
	}

	# Frontend SPA (static files)
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}

	# Security headers
	header {
		# HSTS
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
		# XSS protection
		X-XSS-Protection "1; mode=block"
		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"
		# Frame options
		X-Frame-Options "DENY"
	}

	# Compression
	encode gzip zstd

	# Logging
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}

	# TLS configuration (auto-managed by Caddy)
	# Caddy automatically provisions certificates from Let's Encrypt
	# for .app domains (which require HTTPS)
}

# Redirect www to non-www
www.yuoyuo.app {
	redir https://yuoyuo.app{uri}
}
