# Heart AI Companion - Environment Variables
# Copy to .env and fill in your values

# ─── Application ───
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql+asyncpg://heart:heartdev@localhost:5432/heart
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ─── LLM Providers ───
# DeepSeek only (MVP phase)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional: extra comma-separated DeepSeek keys for the outbound rotation pool.
# Leave empty for single-key. Only use keys you're entitled to (check vendor ToS
# before using multiple accounts to raise concurrency).
DEEPSEEK_API_KEYS=

# ─── Outbound concurrency / failover (see llm_providers/pool.py) ───
# Process-global cap on simultaneous DeepSeek calls (per app process/replica).
LLM_MAX_CONCURRENCY=8
# Retries on 429/5xx (fails over to another key in the pool).
LLM_MAX_RETRIES=2
# Seconds a key is skipped after it returns 429.
LLM_KEY_COOLDOWN_SECONDS=15

# ─── Model Configuration ───
# Primary model for main responses (high quality)
MAIN_LLM_MODEL=deepseek-chat
# Fast/cheap model for encoding, safety, etc.
# Note: deepseek-reasoner is expensive; deepseek-chat is recommended for CHEAP_LLM_MODEL
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service (语义召回) ───
# 留空 EMBEDDING_API_KEY 则语义召回禁用，记忆退回 recency/identity（系统正常不崩）。
# 填入托管 embedding key（OpenAI 兼容，默认 SiliconFlow bge-m3 1024 维）即启用。
# 启用后需跑迁移 017 + backfill_embeddings.py（见 docs/EXECUTION_MANUAL.md §7）。secret 勿提交。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_TTL=86400

# ─── Security / Auth ───
# Development: use HS256 with a random secret (simpler for local dev)
# Production: use RS256 with RSA keypair (see .env.prod.example)
#
# Dev quick start (HS256):
#   1. Set JWT_ALGORITHM=HS256
#   2. Generate: openssl rand -hex 32  → paste below as JWT_SECRET_KEY
#   3. Leave JWT_PRIVATE_KEY and JWT_PUBLIC_KEY empty
#
# Prod (RS256):
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
# Generate pepper with: openssl rand -hex 32
OTP_PEPPER=change-me-otp-pepper-32chars-min
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

# ─── Email (anonymized transactional API) ───
EMAIL_PROVIDER=smtp            # resend | brevo | fallback | smtp(仅本地调试)
EMAIL_FROM=noreply@mail.yuoyuo.app
EMAIL_FROM_NAME=yuoyuo
RESEND_API_KEY=                # 仅存服务端 secret，勿入库勿提交
BREVO_API_KEY=                 # 可选备份商
# SMTP_* 仅本地/离线调试用，生产留空
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Credits / Billing (centesimal: 1 display credit = 100 fen internally) ───
# SIGNUP_GRANT_CREDITS: 10000 = 100 display credits granted at signup
# CREDITS_PER_TEXT_TURN / CREDITS_PER_VOICE_TURN: legacy turn billing (kept for reference)
# CREDITS_COST_TEXT_MESSAGE / CREDITS_COST_VOICE_MESSAGE: active per-bubble billing
SIGNUP_GRANT_CREDITS=10000
CREDITS_PER_TEXT_TURN=100
CREDITS_PER_VOICE_TURN=500
CREDITS_COST_TEXT_MESSAGE=50
CREDITS_COST_VOICE_MESSAGE=500
AFDIAN_USER_ID=
AFDIAN_WEBHOOK_TOKEN=
AFDIAN_SPONSOR_URL=https://afdian.com/a/yuoyuo

# ─── S3 / Object Storage (optional, for local dev use MinIO) ───
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=heart-dev
S3_REGION=us-east-1

# ─── CORS ───
# Comma-separated list of allowed origins. Add your Cloudflare Tunnel URL here
# for phone testing (e.g. https://your-tunnel.trycloudflare.com).
# Leave empty to allow all origins in dev (or set to http://localhost:5173).
CORS_ALLOWED_ORIGINS=

# ─── Observability ───
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=

# ─── Rate Limiting ───
RATE_LIMIT_PER_USER=60  # turns per minute
RATE_LIMIT_PER_IP=200   # requests per minute

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0  # USD
ALERT_COST_THRESHOLD=5.0    # USD

# ─── Feature Flags ───
ENABLE_VOICE=false
ENABLE_VIDEO=false
ENABLE_CRITIC_AGENT=true
CRITIC_SAMPLING_RATE=0.3
ENABLE_WELLBEING_MONITOR=true

# ─── Background Workers ───
# HEART_WORKERS_ENABLED: set to true in the dedicated worker process only.
# In dev, workers run inside the main API process when set to true.
# In prod docker-compose, the encoder-worker service sets this to true.
HEART_WORKERS_ENABLED=false

# ─── Inner Loop (Proactive Messages) ───
# AI 主动发消息功能：开启后 AI 会在满足条件时主动发送消息
# HEART_INNER_LOOP_ENABLED: 是否启用（true/false，默认 false）
# HEART_INNER_LOOP_INTERVAL_S: 检查间隔（秒，默认 3600 = 1小时）
HEART_INNER_LOOP_ENABLED=false
HEART_INNER_LOOP_INTERVAL_S=3600
# PROACTIVE_LLM_ENABLED: use LLM to personalize proactive messages (falls back to templates on failure)
PROACTIVE_LLM_ENABLED=true

# ─── Push Notifications (V1) ───
FCM_CREDENTIALS_PATH=
APNS_CREDENTIALS_PATH=

# ─── Payment (V1) ───
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── MiniMax TTS ───
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Mainland China endpoint (required when using UGC/cloned voice IDs starting with "UGC_"):
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# Optional: extra comma-separated MiniMax keys / group_ids for the TTS rotation pool
# (paired positionally; missing group_ids fall back to MINIMAX_GROUP_ID). MiniMax
# account concurrency caps are typically single-digit — this + TTS_MAX_CONCURRENCY are
# the main defenses against voice-burst 429s.
MINIMAX_API_KEYS=
MINIMAX_GROUP_IDS=
# TTS model and language settings
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_LANGUAGE_BOOST=Chinese
# Process-global cap on simultaneous TTS synthesis (per app process/replica).
TTS_MAX_CONCURRENCY=4
TTS_MAX_RETRIES=1
TTS_KEY_COOLDOWN_SECONDS=20
VOICE_PROFILES=
# Example:
# VOICE_PROFILES={"rin":{"voice_id":"RinClone_20260705","clone_stability":true,"allowed_emotions":["neutral"],"speed_range":[0.98,1.02],"pitch_range":[-1,0],"max_cues":1}}
# Custom-cloned voice IDs for the two built-in characters. When set, override
# the MiniMax preset voices (`female-shaonv` / `female-yujie`) for every
# rin / dorothy reply. Create via `backend/scripts/create_minimax_clone_voice.py`.
MINIMAX_RIN_CLONE_VOICE_ID=
MINIMAX_DOROTHY_VOICE_ID=

# ─── MiMo TTS (voicedesign v2.5) ───
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1  # Token Plan keys use: https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-tts-voiceclone
MIMO_REFERENCE_AUDIO_PATH=assets/reference_voices/rin.wav
VOICE_PROVIDER=mimo  # "mimo" | "minimax"
VOICE_FALLBACK_ENABLED=true
