# Heart AI Companion - Environment Variables
# Copy to .env and fill in your values

# ─── Application ───
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql+asyncpg://heart:heartdev@localhost:5432/heart
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ─── LLM Providers ───
# DeepSeek only (MVP phase)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Model Configuration ───
# Primary model for main responses (high quality)
MAIN_LLM_MODEL=deepseek-reasoner
# Fast/cheap model for encoding, safety, etc.
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service ───
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_TTL=86400

# ─── Security ───
# Generate key with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
# MVP uses HS256 (symmetric). To upgrade to RS256 (asymmetric):
#   1) Generate keypair: openssl genpkey -algorithm RSA -out private.pem && openssl rsa -pubout -in private.pem -out public.pem
#   2) Set JWT_PRIVATE_KEY / JWT_PUBLIC_KEY instead of JWT_SECRET_KEY
#   3) Update JWT_ALGORITHM below to RS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# ─── S3 / Object Storage (optional, for local dev use MinIO) ───
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=heart-dev
S3_REGION=us-east-1

# ─── Observability ───
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=

# ─── Rate Limiting ───
RATE_LIMIT_PER_USER=60  # turns per minute
RATE_LIMIT_PER_IP=200   # requests per minute

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0  # USD
ALERT_COST_THRESHOLD=5.0    # USD

# ─── Feature Flags ───
ENABLE_VOICE=false
ENABLE_VIDEO=false
ENABLE_CRITIC_AGENT=true
CRITIC_SAMPLING_RATE=0.3
ENABLE_WELLBEING_MONITOR=true

# ─── Push Notifications (V1) ───
FCM_CREDENTIALS_PATH=
APNS_CREDENTIALS_PATH=

# ─── Payment (V1) ───
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
