# Heart AI Companion - Environment Variables
# Copy to .env and fill in your values

# ─── Application ───
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql+asyncpg://heart:heartdev@localhost:5432/heart
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ─── LLM Providers ───
# DeepSeek only (MVP phase)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Model Configuration ───
# Primary model for main responses (high quality)
MAIN_LLM_MODEL=deepseek-chat
# Fast/cheap model for encoding, safety, etc.
CHEAP_LLM_MODEL=deepseek-chat

# ─── Embedding Service (语义召回) ───
# 留空 EMBEDDING_API_KEY 则语义召回禁用，记忆退回 recency/identity（系统正常不崩）。
# 填入托管 embedding key（OpenAI 兼容，默认 SiliconFlow bge-m3 1024 维）即启用。
# 启用后需跑迁移 017 + backfill_embeddings.py（见 docs/EXECUTION_MANUAL.md §7）。secret 勿提交。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_TTL=86400

# ─── Security / Auth ───
# Generate key with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
# RS256 (default for commercial):
#   1) Generate keypair: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048 && openssl rsa -pubout -in private.pem -out public.pem
#   2) Paste PEM contents below (single line, escape newlines)
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
# Generate pepper with: openssl rand -hex 32
OTP_PEPPER=change-me-otp-pepper-32chars-min
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

# ─── Email (SMTP) ───
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM="yuoyuo <no-reply@yuoyuo.app>"

# ─── Credits / Billing ───
SIGNUP_GRANT_CREDITS=100
CREDITS_PER_TEXT_TURN=1
CREDITS_PER_VOICE_TURN=5
AFDIAN_USER_ID=
AFDIAN_WEBHOOK_TOKEN=
AFDIAN_SPONSOR_URL=https://afdian.com/a/yuoyuo

# ─── S3 / Object Storage (optional, for local dev use MinIO) ───
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=heart-dev
S3_REGION=us-east-1

# ─── Observability ───
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=

# ─── Rate Limiting ───
RATE_LIMIT_PER_USER=60  # turns per minute
RATE_LIMIT_PER_IP=200   # requests per minute

# ─── Cost Limits ───
USER_DAILY_COST_LIMIT=10.0  # USD
ALERT_COST_THRESHOLD=5.0    # USD

# ─── Feature Flags ───
ENABLE_VOICE=false
ENABLE_VIDEO=false
ENABLE_CRITIC_AGENT=true
CRITIC_SAMPLING_RATE=0.3
ENABLE_WELLBEING_MONITOR=true

# ─── Push Notifications (V1) ───
FCM_CREDENTIALS_PATH=
APNS_CREDENTIALS_PATH=

# ─── Payment (V1) ───
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── MiniMax TTS ───
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.io/v1
VOICE_PROFILES=
# Example:
# VOICE_PROFILES={"rin":{"voice_id":"RinClone_20260705","clone_stability":true,"allowed_emotions":["neutral"],"speed_range":[0.98,1.02],"pitch_range":[-1,0],"max_cues":1}}

# ─── MiMo TTS (voicedesign v2.5) ───
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1  # Token Plan keys use: https://token-plan-cn.xiaomimimo.com/v1
VOICE_PROVIDER=mimo  # "mimo" | "minimax"
VOICE_FALLBACK_ENABLED=true
